# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   usually handled by the user. Everything else should be tracked.
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not commit Pipfile.lock to libraries.
#   User reports that listed packages are not installed with 'pipenv install'.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   However, for libraries, you might want to ignore it.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# .pdm-python
# .pdm-build/

# PEP 582; used by e.g. github.com/fannheyward/coc-pyright
